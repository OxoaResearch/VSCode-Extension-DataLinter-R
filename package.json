{
  "name": "vscode-extension-datalinter-r",
  "displayName": "VSCode Extension for DataLinter R",
  "description": "Visual Studio Code Extension for DataLinter R",
  "version": "0.1.0",
  "publisher": "OxoaResearch",
  "repository": {
    "type": "git",
    "url": "https://github.com/OxoaResearch/VSCode-Extension-DataLinter-R.git"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Data Science"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "r-server-runner.runTool",
        "title": "Analyze Selection with DataLinter for R",
        "category": "R Tools"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorLangId == r && editorHasSelection",
          "command": "r-server-runner.runTool",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "DataLinter for R Server Runner",
      "properties": {
        "rServerRunner.serverUrl": {
          "type": "string",
          "default": "http://localhost:10000/api/lint",
          "description": "The local endpoint for the Data Linter for R server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "axios": "^1.15.1"
  }
}